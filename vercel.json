{
  "version": 2,
  "name": "emotion-dice-v2",
  "builds": [
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "analytics.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/analytics.html",
      "dest": "/analytics.html"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
